        },
        "final_response_match_v2": {
          "threshold": 0.8,
          "judge_model_options": {
            "judge_model": "openai/gpt-4o-mini",
            "num_samples": 5
          }
        }
      },
      "notes": "IN_ORDER: list_centers_by_city before list_available_slots with returned center_ids."
    }
